# Env for DeployAndRenounce.s.sol — append to contracts/.env (git-ignored, NEVER commit).
#
# THREE distinct keys/addresses. The whole renounce story depends on them being separate.

# 1. Deployer = owner (the key that calls renounce). Fresh wallet, ~$10 ETH on Base for gas.
PRIVATE_KEY=0x...

# 2. INDEPENDENT relayer — a SEPARATE address from the deployer. Its PRIVATE key lives in the
#    off-chain relayer process (M3) that calls submitRiskScore. The script hard-requires
#    RELAYER_ADDRESS != deployer; submitRiskScore survives renounce because relayer is set here.
RELAYER_ADDRESS=0x...

# 3. Verified recipient = resolved address of shelter-fund.eth (rule 4 allowlist). Frozen at renounce.
VERIFIED_RECIPIENT=0x...

# --- optional ---
# Base mainnet USDC is the default; only override if you know why.
# USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Fund the pool in the same tx (USDC base units, 6 decimals). Deployer must already hold it.
# Leave unset to fund via the LI.FI donation flow or a manual transfer instead.
# POOL_FUNDING=30000000   # 30 USDC

# IRREVERSIBLE. Leave unset/false while rehearsing. Set true ONLY on the final demo instance.
# RENOUNCE=true
